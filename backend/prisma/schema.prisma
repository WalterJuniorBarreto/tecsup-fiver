generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  username         String?   @unique  
  password         String?
  role             UserRole  @default(CLIENT)
  name             String?  
  provider         AuthProvider  @default(LOCAL)
  avatar           String?   
  
  isVerified       Boolean   @default(false)
  verificationCode String?   
  codeExpiresAt    DateTime?
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  services         Service[] @relation("UserServices") 
  ordersMade       Order[]   @relation("BuyerOrders")  
  ordersGotten     Order[]   @relation("SellerOrders") 

  professionalTitle String?
  location          String?
  bio               String?   @db.Text
  rateType          RateType  @default(NEGOTIABLE)
  hourlyRate        Decimal?  @db.Decimal(10, 2)
  languages         Json?     

  skills            String[]  @default([]) 
  yearsOfExperience Int?      @default(0)
  education   String[] @default([])
  portfolioUrl      String?  

  membershipTier     MembershipTier      @default(FREE)
  subscriptionStatus SubscriptionStatus? @default(INACTIVE)
  subscriptionId     String?             @unique 
  subscriptionEndsAt DateTime?

  conversationsA Conversation[] @relation("ConversationsA")
   conversationsB Conversation[] @relation("ConversationsB")
 messagesSent   Message[]

}
model Service {
  id           String   @id @default(uuid())
  title        String   
  description  String
  price        Float    
  deliveryDays Int      @default(1) 
  image        String?  
  isPublished  Boolean  @default(true)
  
  sellerId     String
  seller       User     @relation("UserServices", fields: [sellerId], references: [id])
  
  orders       Order[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Order {
  id           String      @id @default(uuid())
  amount       Float       
  status       OrderStatus @default(PENDING)
  
  buyerId      String
  buyer        User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  
  sellerId     String
  seller       User        @relation("SellerOrders", fields: [sellerId], references: [id])
  
  serviceId    String
  service      Service     @relation(fields: [serviceId], references: [id])

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

enum OrderStatus {
  PENDING     
  IN_PROGRESS  
  COMPLETED    
  CANCELLED  
}

enum UserRole {
  CLIENT
  FREELANCER
}

enum AuthProvider {
  LOCAL
  GOOGLE
  GITHUB
}

enum RateType {
  HOURLY
  FIXED
  NEGOTIABLE
}

enum MembershipTier {
  FREE
  PRO
  ELITE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE  
  CANCELED  
  INACTIVE 
}


model Conversation {
  id             String    @id @default(uuid())
  
  participantAId String
  participantBId String
  participantA   User      @relation("ConversationsA", fields: [participantAId], references: [id])
  participantB   User      @relation("ConversationsB", fields: [participantBId], references: [id])
  
  messages       Message[]
  
  deletedByA     Boolean   @default(false)
  deletedByB     Boolean   @default(false)
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([participantAId, participantBId])
}

model Message {
  id             String       @id @default(uuid())
  content        String
  isRead         Boolean      @default(false)
  
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime     @default(now())
}